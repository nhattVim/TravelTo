# Server
SERVER_PORT=8080

# Database (default in-memory H2)
DB_URL=jdbc:h2:mem:travelto;MODE=MySQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver

# Security
APP_JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
APP_JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@travelto.vn

# CORS
FE_ORIGIN=http://localhost:3000
